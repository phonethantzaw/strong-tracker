# ---- Convex (local DEV only) ----
# `bunx convex dev` writes CONVEX_DEPLOYMENT + NEXT_PUBLIC_CONVEX_URL for your
# dev deployment (e.g. precise-eel-800). Do NOT put production URLs here.
NEXT_PUBLIC_CONVEX_URL=https://your-dev-deployment.convex.cloud

# ---- Clerk ----
# From the Clerk dashboard -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Optional: where Clerk sends users for sign-in/up (defaults are fine)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# NOTE: CLERK_JWT_ISSUER_DOMAIN is NOT set here.
# It goes in the Convex dashboard (Settings -> Environment Variables),
# because the Convex backend is what verifies the Clerk token.

# ---- Convex program videos (set in Convex dashboard, not .env.local) ----
# Per deployment (dev vs prod), add in Convex dashboard -> Settings -> Environment Variables:
#   WARMUP_VIDEO_ID    = storage ID from Convex Files (warmup .mp4)
#   COOLDOWN_VIDEO_ID  = storage ID from Convex Files (cool-down .mp4)
# Dev and prod use different storage IDs for the same files.
